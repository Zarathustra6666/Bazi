{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Vault/tools/lint_wiki.py C:/Bazi || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Vault/tools/research_orchestrator.py check || true"
          }
        ]
      }
    ]
  }
}
